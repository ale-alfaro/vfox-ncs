#!/usr/bin/env bash
#MISE description="Run plugin tests - install and verify NCS toolchain"
#MISE hide=true
#USAGE arg "<backend>" help="Backend to test" env="BACKEND_UNDER_TEST"
#USAGE arg "<version>" help="Backend version to test with" env="BACKEND_TEST_VERSION"
#USAGE arg "<test_tools>" help="File with Backend tools to test with"
set -euo pipefail

fail() {
  echo "вљ  FAIL: $*"
  exit 1
}
pass() {
  echo "вњ“ PASS: $*"
}

has() {
  type "$1" &>/dev/null
}

join_args() {
  printf '%q ' "$@"
}

BACKEND="${usage_backend:?}"
BACKEND_VERSION="${usage_version:?}"
declare -A TEST_TOOLS
declare -A TOOL_VERSIONS

mapfile -t cmds <"${usage_test_tools?}"
for cmd in "${cmds[@]}"; do
  key="${cmd%%=*}"
  val="${cmd#*=}"
  # Support optional per-tool version: tool@version=command
  if [[ "$key" == *@* ]]; then
    tool="${key%%@*}"
    TOOL_VERSIONS[$tool]="${key#*@}"
  else
    tool="$key"
    TOOL_VERSIONS[$tool]="$BACKEND_VERSION"
  fi
  TEST_TOOLS[$tool]="$val"
done
echo "BACKEND=${BACKEND}  BACKEND_VERSION=$BACKEND_VERSION  TEST_TOOLS=${!TEST_TOOLS[*]}"

cleanup() {
  echo "Cleaning up installed tools..."
  for tool in "${!TEST_TOOLS[@]}"; do
    ver="${TOOL_VERSIONS[$tool]}"
    mise uninstall "${BACKEND}:${tool}@${ver}" 2>/dev/null || true
  done
}
trap cleanup EXIT

# в”Ђв”Ђ Link and install plugin в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
mise plugins link --force "${BACKEND}" "${MISE_CONFIG_ROOT:?}"
mise cache clear

# Test that the plugin can list tools (this should work even if no tools are available)
echo "Testing plugin linking and basic functionality..."
for tool in "${!TEST_TOOLS[@]}"; do
  ver="${TOOL_VERSIONS[$tool]}"
  echo "TESTING TOOL: ${tool}@${ver}"
  # в”Ђв”Ђ available versions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  echo "Testing version listing..."
  if mise ls-remote "${BACKEND}:${tool}" 2>/dev/null; then
    pass "${tool} version listing works"
  else
    fail "${tool} version listing failed - check backend_list_versions.lua"
  fi
  # в”Ђв”Ђ installationв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  echo "Installing ${tool}@${ver}..."
  if mise install "${BACKEND}:${tool}@${ver}" 2>/dev/null; then
    pass "${tool} installation works"
  else
    fail "${tool} installation failed"
  fi
  test_cmd="${TEST_TOOLS[$tool]}"

  echo "Executing test command: ${test_cmd?}"
  # в”Ђв”Ђ executionв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if mise exec "${BACKEND}:${tool}@${ver}" -- ${test_cmd} 2>/dev/null; then
    pass "Tool execution works: ${tool}"
  else
    fail "Tool execution failed: ${tool} - check backend_exec_env.lua implementation"

  fi
done

pass "Backend plugin smoke tests completed for ${BACKEND}"
