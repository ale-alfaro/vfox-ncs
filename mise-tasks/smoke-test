#!/usr/bin/env bash
#MISE description="Smoke test all tools for a backend version"
#MISE hide=true
#MISE dir="{{cwd}}"
set -euo pipefail

: "${BACKEND:?Set BACKEND env var}"
: "${BACKEND_VERSION:?Set BACKEND_VERSION env var}"

declare -a TOOLS
TOOLS=("nrfutil" "west")

echo "BACKEND=${BACKEND}  VERSION=${BACKEND_VERSION}"
for tool in "${TOOLS[@]}"; do
  echo "── ${tool}@${BACKEND_VERSION} ──"
  echo "Testing version listing..."
  mise ls-remote "${BACKEND}:${tool}"
  echo "Executing: "
  mise x -- "${tool}" --version
done

pass "All smoke tests passed for ${BACKEND}@${BACKEND_VERSION}"
