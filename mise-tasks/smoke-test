#!/usr/bin/env bash
#MISE description="Run plugin tests - install and verify NCS toolchain"
#USAGE arg "<ncs_version>" help="NCS version to test with" env="NCS_TEST_VERSION"
set -euo pipefail
NCS_VERSION="${usage_ncs_version:?}"
TEST_TOOLS=( "python" "west" "arm-zephyr-eabi-gcc" )

echo "NCS_VERSION=$NCS_VERSION TEST_TOOLS=${TEST_TOOLS[*]}"
# ── Link and install plugin ──────────────────────────────────────────
mise plugins link --force ncs "${MISE_CONFIG_ROOT:?}"
mise cache clear

# Test that the plugin can list tools (this should work even if no tools are available)
echo "Testing plugin linking and basic functionality..."

# Try to list available versions for a test tool
# Note: This will likely fail until you implement the backend methods
# Replace <TEST_TOOL> with a real tool name your backend supports

echo "Testing version listing for ${TEST_TOOLS[*]}..."
if mise ls-remote "ncs:toolchain-manager@${NCS_VERSION}" 2>/dev/null; then
  echo "✓ Version listing works"
else
  echo "⚠ Version listing failed - implement backend_list_versions.lua for your backend"
fi

# Test installation if versions are available
echo "Testing installation..."
if mise install "ncs:toolchain-manager@${NCS_VERSION}" 2>/dev/null; then
  echo "✓ Installation works"

  for tool in ${TEST_TOOLS}; do

    echo "Testing tool: ${tool}"
    if mise exec "ncs:toolchain-manager@${NCS_VERSION}" -- "${tool:?}" --version 2>/dev/null; then
      echo "✓ Tool execution works"
    else
      echo "⚠ Tool execution failed - check backend_exec_env.lua implementation"
    fi
  done
  # Test that the tool can be executed
else
  echo "⚠ Installation failed - implement backend_install.lua for your backend"
fi
echo "✓ Basic plugin structure tests completed"
