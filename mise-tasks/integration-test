#!/usr/bin/env bash
#MISE description="Integration test - build a NCS sample with the NCS toolchain"
#MISE hide=true
set -euo pipefail

: "${BACKEND:?Set BACKEND env var}"
: "${BACKEND_VERSION:?Set BACKEND_VERSION env var}"

fail() { echo "⚠ FAIL: $*"; exit 1; }
pass() { echo "✓ PASS: $*"; }

WORKSPACE="$(mktemp -d)"

# cmsis was renamed to cmsis_6 in NCS ~3.2.0
if printf '%s\n%s\n' "3.2.0" "${BACKEND_VERSION}" | sort -V | head -1 | grep -q "^3.2.0$"; then
  CMSIS_MODULE="cmsis_6"
else
  CMSIS_MODULE="cmsis"
fi

cleanup() {
  echo "Cleaning up..."
  mise uninstall "${BACKEND}:west@${BACKEND_VERSION}" 2>/dev/null || true
  mise uninstall "${BACKEND}:toolchain@${BACKEND_VERSION}" 2>/dev/null || true
  rm -rf "$WORKSPACE"
}
trap cleanup EXIT

echo "WORKSPACE=${WORKSPACE}  BACKEND_VERSION=${BACKEND_VERSION}"
APPDIR="${WORKSPACE}/app"

# ── Write minimal west manifest ────────────────────────────────────
mkdir -p "${APPDIR}"
cat >"${APPDIR}/west.yml" <<YAML
manifest:
  remotes:
    - name: ncs
      url-base: https://github.com/nrfconnect
  projects:
    - name: sdk-nrf
      remote: ncs
      path: nrf
      revision: v${BACKEND_VERSION}
      clone-depth: 1
      import:
        name-allowlist:
          - zephyr
          - ${CMSIS_MODULE}
          - hal_nordic
          - nrfxlib
  self:
    path: app
YAML

# ── West init & update ─────────────────────────────────────────────
cd "${APPDIR}"
mise x "${BACKEND}:west@${BACKEND_VERSION}" -- west init -l .
WEST_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/ncs-plugin-test/west"
mkdir -p "${WEST_CACHE}"
mise x "${BACKEND}:west@${BACKEND_VERSION}" -- west update -o=--depth=1 --narrow --auto-cache "${WEST_CACHE}"
mise set ZEPHYR_BASE="$WORKSPACE/zephyr"
mise x "${BACKEND}:toolchain@${BACKEND_VERSION}" -- west build -p -b nrf52840dk/nrf52840 "${WORKSPACE}/zephyr/samples/hello_world" --no-sysbuild

# ── Verify output ──────────────────────────────────────────────────
if [[ -d build && -e build/zephyr/zephyr.elf ]]; then
  pass "Integration test: zephyr.elf built successfully"
else
  fail "Integration test: build/zephyr/zephyr.elf not found"
fi
