#!/usr/bin/env bash
#MISE description="Integration test - build a NCS sample with the NCS toolchain"
#USAGE arg "<dir>" help="Workspace directory"
#USAGE arg "<ncs_version>" help="NCS version to test with" env="NCS_TEST_VERSION"

set -euo pipefail
WORKSPACE="${usage_dir:?}"
NCS_VERSION="${usage_ncs_version:?}"

echo "WORKSPACE=${WORKSPACE} NCS_VERSION=$NCS_VERSION"
pushd "${WORKSPACE}"
APPDIR="${WORKSPACE?}/app"

# cmsis was renamed to cmsis_6 in NCS ~3.2.0
if printf '%s\n%s\n' "3.2.0" "${NCS_VERSION}" | sort -V | head -1 | grep -q "^3.2.0$"; then
  CMSIS_MODULE="cmsis_6"
else
  CMSIS_MODULE="cmsis"
fi
cleanup() {
  echo "Cleanup!"
  rm -rf "$WORKSPACE"
}
trap cleanup EXIT

# Try to list available versions for a test tool
# Note: This will likely fail until you implement the backend methods
# Replace <TEST_TOOL> with a real tool name your backend supports
# ── Install toolchain ──────────────────────────────────────────────
mise plugins link --force ncs "${MISE_CONFIG_ROOT:?}"
mise cache clear
mise ls-remote ncs:toolchain-manager
mise install "ncs:toolchain-manager@${NCS_VERSION}"
mise x "ncs:toolchain-manager@${NCS_VERSION}" -- arm-zephyr-eabi-gcc --version
mise x "ncs:toolchain-manager@${NCS_VERSION}" -- python --version
mise x "ncs:toolchain-manager@${NCS_VERSION}" -- west --version

# ── Write minimal west manifest ────────────────────────────────────
mkdir "${APPDIR?}"
cat >"${APPDIR}/west.yml" <<YAML
manifest:
  remotes:
    - name: ncs
      url-base: https://github.com/nrfconnect

  projects:
    - name: sdk-nrf
      remote: ncs
      path: nrf
      revision: v${NCS_VERSION}
      clone-depth: 1
      import:
        name-allowlist:
          - zephyr
          - ${CMSIS_MODULE}
          - hal_nordic
          - nrfxlib

  self:
    path: app
YAML

# ── West init & update ─────────────────────────────────────────────
pushd "${APPDIR}"
# PYTHON_VERSION=$(mise env --json | jq -r '.NCS_PYTHON_VERSION')
mise x pipx:west@1.5.0 -- west init -l .
WEST_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/ncs-plugin-test/west"
mkdir -p "${WEST_CACHE}"
mise x pipx:west@1.5.0 -- west update -o=--depth=1 --narrow --auto-cache "${WEST_CACHE}"
# mise use ncs:toolchain-manager
# mise run "$MISE_ORIGINAL_CWD/mise-tasks/uv-init" -r "${WORKSPACE}/zephyr/scripts/requirements.txt"
mise set ZEPHYR_BASE="$WORKSPACE/zephyr"
mise x "ncs:toolchain-manager@${NCS_VERSION}" -- west build -p -b nrf52840dk/nrf52840 "${WORKSPACE}/zephyr/samples/hello_world" --no-sysbuild

# ── Verify output ──────────────────────────────────────────────────
if [[ -d build && -e build/zephyr/zephyr.elf ]]; then
  echo "Integration test passed: zephyr.elf built successfully"
else
  echo "Integration test failed: build/zephyr/zephyr.elf not found"
  exit 1
fi
popd
